# mlearnweb backend 配置模板
#
# 用法：
#   1. 复制为 .env：    cp .env.example .env
#   2. 编辑你的值（路径、密码、节点 yaml 位置）
#   3. 重启 app.main / app.live_main 后生效
#
# 字段分类：
#   [bootstrap] —— 必须改 .env + 重启进程；不可在前端 UI 改
#   [runtime]   —— /settings/runtime 或 /settings/system 页可在线编辑（DB 覆盖优先）
#                  这里写的是 .env 默认值；DB 没写时回退到这里
#
# 字段命名约定：env 变量名 = 大写 + 下划线，对应 app/core/config.py 中的 settings 字段。

# ============================================================================
# [bootstrap] MLflow / 数据库 / 上传目录
# ============================================================================

# MLflow tracking 根目录（绝对路径推荐）
MLRUNS_DIR=F:\Quant\code\qlib_strategy_dev\mlruns

# SQLite 路径（相对路径基于 backend/ 工作目录；生产建议绝对路径）
DATABASE_URL=sqlite:///./mlearnweb.db

# 上传目录（StaticFiles 启动时挂载）；不设则取 backend/uploads/
# UPLOAD_DIR=/var/lib/mlearnweb/uploads

# CORS 允许域（JSON 数组）
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000","http://127.0.0.1:5173"]


# ============================================================================
# [bootstrap] 远端策略机产物的本地视图（不是权威配置！）
# ----------------------------------------------------------------------------
# 重要：下面两个变量都不是 mlearnweb 「定义」的；mlearnweb 只是这些文件的
# 读方。权威配置在 vnpy_strategy_dev 仓库：
#
#   DAILY_MERGED_ROOT 的写方：
#     vnpy_strategy_dev/vnpy_tushare_pro/ml_data_build/daily_ingest_pipeline.py
#     由该机器上的 env QS_DATA_ROOT（默认 D:/vnpy_data）控制
#     每天 20:00 cron 把 daily_merged_YYYYMMDD.parquet 落到
#     {QS_DATA_ROOT}/snapshots/merged/
#
#   ML_LIVE_OUTPUT_ROOT 的写方：
#     vnpy_strategy_dev/vnpy_ml_strategy/predictors/qlib_predictor.py
#     由 vnpy 策略实例参数 output_root（默认 D:/ml_output）控制
#     通过 vnpy web UI 在每个策略实例上单独配置
#     运行时把 predictions.parquet 落到 {output_root}/{strategy_name}/{YYYYMMDD}/
#
# mlearnweb 这一侧填的是「**我（mlearnweb）这台机器上看到上述目录的路径**」：
#   - 同机部署（mlearnweb 与 vnpy 同台机器）：填和写方一样的绝对路径
#   - 跨机部署（mlearnweb 在另一台机器）：填本机的 NFS/SMB 挂载点
#
# 改这里只改 mlearnweb 的「读视图」，不会改 vnpy 实际产出位置。两侧不一致
# 时 mlearnweb 看到空目录或读到旧文件。修改步骤一定要：
#   1. 先在策略机上确认或调整写方配置
#   2. 再调整本机挂载（如有需要）
#   3. 最后把这里的路径改成本机看到的实际位置
# ============================================================================

# 日合并 parquet 在 mlearnweb 本机的可见路径
DAILY_MERGED_ROOT=D:\vnpy_data\snapshots\merged

# ML 实盘策略输出根在 mlearnweb 本机的可见路径
# 留空则关闭 backtest-vs-live diff 与 ml prediction 相关接口
# ML_LIVE_OUTPUT_ROOT=


# ============================================================================
# [bootstrap] vnpy 节点配置 / 实盘运维口令
# ============================================================================

# vnpy 节点清单 yaml 路径（live_main 启动时读）
# 默认 backend/vnpy_nodes.yaml；多机部署可放 /etc/mlearnweb/
VNPY_NODES_CONFIG_PATH=./vnpy_nodes.yaml

# 实盘写操作（创建/启停/改参/删策略）所需运维口令
# 留空 = 关闭写鉴权（仅本地开发推荐）；生产必设
# LIVE_TRADING_OPS_PASSWORD=


# ============================================================================
# [runtime] vnpy 客户端 / 轮询 / 同步周期
# ----------------------------------------------------------------------------
# 这里是初始默认；运行后可在 /settings/runtime 页改并存到 DB（即时生效，无需重启）
# ============================================================================

# 单次 HTTP 请求 vnpy 节点的超时（秒）
VNPY_REQUEST_TIMEOUT=10.0

# snapshot_loop 拉取 strategies/positions/account 的轮询周期（秒）
VNPY_POLL_INTERVAL_SECONDS=10

# strategy_equity_snapshots / ml_metric_snapshots 保留天数
VNPY_SNAPSHOT_RETENTION_DAYS=30

# Phase 3B：deployment 同步周期（秒，最小 60）
DEPLOYMENT_SYNC_INTERVAL_SECONDS=600


# ============================================================================
# [runtime] memo 图片上传与孤儿清理
# ----------------------------------------------------------------------------
# 同样可在 /settings/system 页改
# ============================================================================

# 单图最大尺寸（MB）
MAX_IMAGE_SIZE_MB=10

# 允许的图片扩展名（JSON 数组，含小数点）
ALLOWED_IMAGE_EXTS=[".png",".jpg",".jpeg",".webp",".gif"]

# memo 编辑期未保存图片的孤儿宽限期（秒）
ORPHAN_GRACE_SECONDS=300
