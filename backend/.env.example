# mlearnweb backend 配置模板
#
# 用法：
#   1. 复制为 .env：    cp .env.example .env
#   2. 编辑你的值（路径、密码、节点 yaml 位置）
#   3. 重启 app.main / app.live_main 后生效
#
# 字段分类：
#   [bootstrap] —— 必须改 .env + 重启进程；不可在前端 UI 改
#   [runtime]   —— /settings/runtime 或 /settings/system 页可在线编辑（DB 覆盖优先）
#                  这里写的是 .env 默认值；DB 没写时回退到这里
#
# 字段命名约定：env 变量名 = 大写 + 下划线，对应 app/core/config.py 中的 settings 字段。

# ============================================================================
# [bootstrap] MLflow / 数据库 / 上传目录
# ============================================================================

# MLflow tracking 根目录（外部只读挂载；未配置时研究页降级为空，不影响 live-trading）
# MLRUNS_DIR=D:\mlearnweb_data\mlruns

# SQLite 路径（生产建议由 install_all.ps1 写到 DataRoot\db）
DATABASE_URL=sqlite:///D:/mlearnweb_data/db/mlearnweb.db

# 上传目录（StaticFiles 启动时挂载）
UPLOAD_DIR=D:\mlearnweb_data\uploads

# DataRoot 与前端 dist（生产单端口模式）
DATA_ROOT=D:\mlearnweb_data
FRONTEND_DIST_DIR=D:\apps\mlearnweb\frontend\dist

# 聚宽导出目录（默认收敛到 DataRoot）
JOINQUANT_EXPORT_DIR=D:\mlearnweb_data\joinquant_exports

# CORS 允许域（JSON 数组）
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000","http://127.0.0.1:5173"]


# ============================================================================
# [bootstrap] 远端策略机产物的本地视图 (Phase 3 解耦后只剩可选优化项)
# ----------------------------------------------------------------------------
# Phase 3.1-3.4 把所有 mlearnweb 直读 vnpy 推理机本地 parquet 的逻辑搬到
# vnpy webtrader HTTP 端点 (/api/v1/reference/* + /api/v1/ml/* + /api/v1/position/*).
# 跨机部署 mlearnweb 不需要任何本地挂载点, 留所有字段空白即可.
#
# 下方两个字段是同机部署的"快路径"优化, 留空时 mlearnweb 走 HTTP 主路径,
# 有空间就 fail-graceful — 不影响功能, 只是 fallback 不可用.
# ============================================================================

# ML 实盘策略推理产物根目录 (vnpy ml 策略 output_root, 默认 D:/ml_output).
# 留空 → backtest-vs-live diff 路由提示"需配置"; 其他历史预测 / topk 走 HTTP.
# ML_LIVE_OUTPUT_ROOT=D:\ml_output

# [A2] vnpy_qmt_sim 状态目录: 含 sim_<gateway>.db — 持仓 / 订单 / 成交.
# 同机部署: 历史持仓浏览的 sim db fallback 路径直读此目录 (vnpy webtrader RPC
# 不可用时的兜底). 跨机部署留空 — 主路径 /api/v1/position/history 已精确,
# fallback 自动 skip 不报错.
# VNPY_SIM_DB_ROOT=D:\vnpy_data\state


# ============================================================================
# [bootstrap] vnpy 节点配置 / 实盘运维口令
# ============================================================================

# vnpy 节点清单 yaml 路径（live_main 启动时读）
# 默认 backend/vnpy_nodes.yaml；多机部署可放 /etc/mlearnweb/
VNPY_NODES_CONFIG_PATH=D:\mlearnweb_data\config\vnpy_nodes.yaml

# 实盘写操作（创建/启停/改参/删策略）所需运维口令
# 留空 = 关闭写鉴权（仅本地开发推荐）；生产必设
# LIVE_TRADING_OPS_PASSWORD=


# ============================================================================
# [runtime] vnpy 客户端 / 轮询 / 同步周期
# ----------------------------------------------------------------------------
# 这里是初始默认；运行后可在 /settings/runtime 页改并存到 DB（即时生效，无需重启）
# ============================================================================

# 单次 HTTP 请求 vnpy 节点的超时（秒）
VNPY_REQUEST_TIMEOUT=10.0

# snapshot_loop 拉取 strategies/positions/account 的轮询周期（秒）
VNPY_POLL_INTERVAL_SECONDS=10

# P1 事件中台 REST 指纹检测周期（秒）。vnpy WS 接入前用于触发 SSE query invalidation。
LIVE_TRADING_EVENT_FINGERPRINT_INTERVAL_SECONDS=5

# strategy_equity_snapshots / ml_metric_snapshots 保留天数
VNPY_SNAPSHOT_RETENTION_DAYS=30

# Phase 3B：deployment 同步周期（秒，最小 60）
DEPLOYMENT_SYNC_INTERVAL_SECONDS=600


# ============================================================================
# [bootstrap] P1-3 Plan A — vnpy 节点 watchdog + SMTP 告警
# ----------------------------------------------------------------------------
# watchdog_service 周期 probe vnpy 节点, 连续 N 次 offline → 发邮件告警;
# 节点恢复 online → 发恢复邮件. SMTP 字段缺失则只走 log, 不发邮件.
#
# 与 vnpy 进程的告警 (vt_setting.json email.*) 互补:
#   - vnpy 进程挂了 → vnpy 端发不出告警 → mlearnweb watchdog 兜底
#   - mlearnweb 挂了 → 失去 watchdog (但不影响 vnpy 端 ingest_failed 邮件)
#
# 长期升级: 接 Uptime Kuma / Healthchecks.io (见 mlearnweb/docs/operations.md).
# ============================================================================

# 探活周期(秒)
WATCHDOG_PROBE_INTERVAL_SECONDS=60

# 连续 offline 多少次后发邮件 (防止偶发抖动): 3 次 × 60s = 3 分钟检测窗
WATCHDOG_OFFLINE_THRESHOLD=3


# ============================================================================
# [bootstrap] 训练工作台 / 调参集成（可选）
# ----------------------------------------------------------------------------
# 不配置 STRATEGY_DEV_ROOT 时，Workbench 创建/启动/入队入口会禁用；
# dashboard、实验浏览、live-trading 仍正常启动。
# ============================================================================

# STRATEGY_DEV_ROOT=D:\apps\qlib_strategy_dev
# TUNING_PYTHON_EXE=D:\mlearnweb_data\venv\Scripts\python.exe
TUNING_RUNS_ROOT=D:\mlearnweb_data\tuning\runs

# SMTP 凭据 (任一缺失则不发邮件, 只 log warn)
# Gmail: smtp.gmail.com:465 (SSL) 需用 app password
# 163: smtp.163.com:465 (SSL) 需在邮箱后台开启 SMTP 并用授权码
# 公司内邮箱常用: 25 / 587 (STARTTLS, SMTP_USE_SSL=false)
# SMTP_SERVER=smtp.gmail.com
# SMTP_PORT=465
# SMTP_USERNAME=
# SMTP_PASSWORD=
# SMTP_SENDER=
# SMTP_RECEIVER=
# SMTP_USE_SSL=true


# ============================================================================
# [runtime] memo 图片上传与孤儿清理
# ----------------------------------------------------------------------------
# 同样可在 /settings/system 页改
# ============================================================================

# 单图最大尺寸（MB）
MAX_IMAGE_SIZE_MB=10

# 允许的图片扩展名（JSON 数组，含小数点）
ALLOWED_IMAGE_EXTS=[".png",".jpg",".jpeg",".webp",".gif"]

# memo 编辑期未保存图片的孤儿宽限期（秒）
ORPHAN_GRACE_SECONDS=300
